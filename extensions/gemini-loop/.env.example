# Loop extension settings

# State directory for loop persistence
GEMINI_LOOP_STATE_DIR=.agent_working_dir/loops

# Default maximum iterations for loops
GEMINI_LOOP_MAX_ITERATIONS=100

# Default strategy: continue or reset
GEMINI_LOOP_STRATEGY=continue

# Enable ultrawork mode with Oracle verification
GEMINI_LOOP_ULTRAWORK_ENABLED=true

# Oracle model for ultrawork verification
GEMINI_LOOP_ORACLE_MODEL=gemini-2.5-pro

# API timeout in milliseconds
GEMINI_LOOP_API_TIMEOUT=5000

# Debug mode for verbose logging
GEMINI_LOOP_DEBUG=false

# Log file path for debug output
GEMINI_LOOP_LOG_FILE=.gemini-loop-debug.log
